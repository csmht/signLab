# ===================================
# SignLab1 环境配置（示例文件）
# 复制本文件为 local-config.env 并填入实际值
# ===================================

# --------------------
# 数据库配置
# --------------------
# 数据库连接地址
DB_HOST=your_db_host

# 数据库端口
DB_PORT=3306

# 数据库名称
DB_NAME=signlab1

# 数据库用户名
DB_USERNAME=your_db_username

# 数据库密码
DB_PASSWORD=your_db_password

# --------------------
# 服务器配置
# --------------------
# 服务器端口，默认8085
SERVER_PORT=8085

# 服务器地址，0.0.0.0表示监听所有地址，127.0.0.1表示仅本地访问
SERVER_ADDRESS=127.0.0.1

# --------------------
# 文件上传配置
# --------------------
# 文件上传路径，建议使用绝对路径
# Windows示例: C:/opt/signlab/uploads/
# Linux/Mac示例: /opt/signlab/uploads/
UPLOAD_PATH=./uploads/signlab/

# 单个文件最大大小，默认500MB
MAX_FILE_SIZE=500MB

# 单次请求最大大小，默认500MB
MAX_REQUEST_SIZE=500MB

# --------------------
# JWT配置
# --------------------
# JWT签名密钥，用于加密和解密token，请使用强密码
JWT_SECRET=your_jwt_secret_key

# JWT过期时间，单位：秒，2592000 = 30天
JWT_EXPIRATION=2592000

# 测试环境JWT配置
JWT_IS_TEXT=true

# --------------------
# 微信公众号配置
# --------------------
# 微信公众号AppID，在微信公众平台获取
WECHAT_APPID=your_wechat_appid

# 微信公众号AppSecret，在微信公众平台获取
WECHAT_SECRET=your_wechat_secret

# 微信公众号模板消息ID
WECHAT_TEMPLATE_ID=your_wechat_template_id

# 微信公众号服务器配置Token，用于验证消息来源
WECHAT_TOKEN=your_wechat_token

# --------------------
# 日志配置
# --------------------
# 应用环境：dev/test/prod
SPRING_PROFILES_ACTIVE=dev

# 日志级别：DEBUG/INFO/WARN/ERROR
LOGGING_LEVEL_ROOT=DEBUG
